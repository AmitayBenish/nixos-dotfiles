//-*- mode: jsonc -*-
{
    "layer": "top", 
    "position": "top", 
    "height": 30, 
    "spacing": 4, 

    // Choose the order of the modules
    "modules-left": [
        "ext/workspaces",
        "custom/tiling_layout",
        "tray"
    ],
    "modules-center": [
    ],

    "modules-right": [
         "custom/keyboard-layout",
        // "custom/sep",
        // "network",
        // "custom/sep",
        // "cpu",
        // "custom/sep",
        // "clock",
        // "custom/sep",
        // "tray",
        // "battery"
        "custom/slstatus"
    ],

    // Modules configuration
    "ext/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "warp-on-scroll": false,
        "format": "{name}",
        "persistent-workspaces": {
            "*" : 9
        }
    },
    "ext/window" : {
        "max-length": 40,
        "seperate-outputs": false
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
        // "icons": {
        //   "blueman": "bluetooth",
        //   "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
        // }
    },
    "clock": {
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "format": "CPU: {usage}%",
        "tooltip": false
    },
    "memory": {
        "format": "Mem: {used}GiB"
    },
    "disk": {
        "interval": 60,
        "path": "/",
        "format": "Disk: {free}"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "Bat: {capacity}% {icon} {time}",
        "format-charging": "Bat: {capacity}%  {time}",
        "format-plugged": "{capacity}% ",
        "format-alt": "Bat: {capacity}%",
        "format-time": "{H}:{M}",
        "format-icons": ["", "", "", "", ""]
    },
    "network": {
        "format": "Online",
        "format-disconnected": "Disconnected ⚠"
    },
    "custom/sep": {
        "format" : "|",
        "interval" : 0
    },
    "custom/keyboard-layout": {
        "exec": "~/.config/mango/current_layout.sh",
        "foramt": "{}"
    },
    "custom/tiling_layout": {
        "exec": "~/.config/mango/current_tiling_layout.sh",
        "format": "{}"
    
    },
    "custom/slstatus": {
        "exec": "slstatus -s",
        "format": "{}"
    }
}
