        },
        "battery": {
            "states": {
                "good": 95,
                "warning": 30,
                "critical": 15
            },
            "format":  "<span size = '125%'>{icon} {time}</span>",
            "format-charging": "<span size = '125%'>{icon}</span>&#8195;<span rise = '5000'>з▒љІ</span>",
            "format-plugged": "<span size = '125%'>{icon} </span>&#8195;<span rise = '5000'>з▒љІ</span>",
            "tooltip-format": "{capacity}%",
            "format-time": "{H}:{M}",
            "format-icons": ["№Ѕё", "№ЅЃ", "№Ѕѓ", "№ЅЂ", "№Ѕђ"]
        },
        "network": {
            "format": "з░ќЪ",
            "format-disconnected": "№ЉД"
        },
        "custom/sep": {
            "format" : "\n",
            "interval" : 0
        },
        "sway/language": {
          "format": "<span size = 'small'>{short}</span>",  
        },
        "sway/layout": {
            "format": "<span size = 'small'>{}</span>",
        },
        "custom/slstatus": {
            "exec": "slstatus -s",
            "format": "{}"
        }
    }
]
